OCR_MAX_FILE_MB=15
OCR_MIN_CONFIDENCE=0.45
OCR_LANG=ne
OCR_VERSION=PP-OCRv5
OCR_TEXT_DETECTION_MODEL=PP-OCRv5_mobile_det
OCR_TEXT_RECOGNITION_MODEL=devanagari_PP-OCRv5_mobile_rec
OCR_USE_GPU=false
OCR_USE_TEXTLINE_ORIENTATION=false
OCR_DET_LIMIT_SIDE_LEN=1280
OCR_DET_LIMIT_TYPE=max
OCR_DET_BOX_THRESH=0.45
OCR_DET_UNCLIP_RATIO=1.8
OCR_CLEAN_BACKGROUND=false
OCR_SAVE_DEBUG=false
OCR_DEBUG_DIR=./debug_ocr
