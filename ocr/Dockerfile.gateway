FROM golang:1.23-bookworm AS build

WORKDIR /src
COPY go.mod .
COPY cmd ./cmd
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/kyc-gateway ./cmd/gateway

FROM alpine:3.20

COPY --from=build /out/kyc-gateway /kyc-gateway
WORKDIR /app
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -qO- http://127.0.0.1:8000/healthz >/dev/null || exit 1

ENTRYPOINT ["/kyc-gateway"]
